<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#121212">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Streamer &amp; Sharing"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="40dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Desktop IP Address:"
        android:textColor="#BBBBBB"
        android:textSize="16sp"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/ipAddressInput"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="e.g., 192.168.1.100"
        android:textColorHint="#666666"
        android:textColor="#FFFFFF"
        android:background="@drawable/edittext_bg"
        android:padding="16dp"
        android:inputType="phone"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Port Number:"
        android:textColor="#BBBBBB"
        android:textSize="16sp"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/portInput"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="8080"
        android:textColorHint="#666666"
        android:textColor="#FFFFFF"
        android:background="@drawable/edittext_bg"
        android:padding="16dp"
        android:inputType="number"
        android:layout_marginBottom="30dp"/>

    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Status: Not Streaming"
        android:textColor="#FF4444"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="30dp"/>

    <Button
        android:id="@+id/toggleStreamButton"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="START STREAMING"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#4CAF50"
        android:layout_marginBottom="12dp"/>
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginBottom="20dp"
        android:layout_marginTop="10dp"/>

    <TextView
        android:id="@+id/ftpStatusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="FTP: Stopped"
        android:textColor="#FF4444"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/toggleFtpButton"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="START FTP SERVER"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2196F3"
        android:layout_marginBottom="12dp"/>
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Note: Ensure your Ubuntu desktop is running the receiver on the same network"
        android:textColor="#666666"
        android:textSize="12sp"
        android:gravity="center"
        android:layout_marginTop="30dp"/>

</LinearLayout>
